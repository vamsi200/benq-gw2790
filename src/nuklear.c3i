constdef Nk_style_item_type : CUInt {
  NK_STYLE_ITEM_COLOR = 0,
  NK_STYLE_ITEM_IMAGE = 1,
  NK_STYLE_ITEM_NINE_SLICE = 2
}

struct Nk_style_item {
  Nk_style_item_type type;
  Nk_style_item_data data;
}

union Nk_style_item_data {
  Nk_color color;
  Nk_image image;
  Nk_nine_slice slice;
}

struct Nk_nine_slice {
  Nk_image img;
  Nk_ushort l;
  Nk_ushort t;
  Nk_ushort r;
  Nk_ushort b;
}

union Nk_handle {
  void* ptr;
  CInt id;
}


alias Nk_ushort = CUShort;

struct Nk_image {
  Nk_handle handle;
  Nk_ushort w;
  Nk_ushort h;
  Nk_ushort[4] region;
}

