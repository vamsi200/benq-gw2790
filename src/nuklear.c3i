struct Nk_font {
    Nk_font*      next;
    Nk_user_font  handle;
}

extern fn void nk_style_set_font(
    Nk_context*,
    Nk_user_font*
) @cname("nk_style_set_font");

alias Nk_font_config = void;

extern fn Nk_font* nk_font_atlas_add_from_file(Nk_font_atlas *atlas, char *file_path, float height, Nk_font_config*)@cname("nk_font_atlas_add_from_file");

alias Nk_text_width_f = fn float(
  Nk_handle,
  float h,
  CChar*,
  CInt len);

struct Nk_user_font {
  Nk_handle userdata;
  float height;
  Nk_text_width_f width;
}

