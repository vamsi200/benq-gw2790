struct Nk_context {
  char[496] pad;
  Nk_style style;
}

struct Nk_style {
  char[104] pre_button_pad;   // offsetof(button) = 104
  Nk_style_button button;     // 216 bytes, ends at 320
  char[1344] pre_slider_pad;  // 1664 - 320 = 1344
  Nk_style_slider slider;     // 776 bytes, ends at 2440
  char[6056] pre_window_pad;  // 8496 - 2440 = 6056
  Nk_style_window window;     // 856 bytes
}

